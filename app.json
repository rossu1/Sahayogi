{
  "expo": {
    "name": "Sahayogi सहायोगी",
    "slug": "sahayogi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D32F2F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sahayogi.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sahayogi needs your location to find nearby responders and send your position in an emergency.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Sahayogi needs background location to share your live position with police during an alert.",
        "NSMotionUsageDescription": "Sahayogi uses motion detection for the shake-to-alert feature."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D32F2F"
      },
      "package": "com.sahayogi.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Sahayogi needs your location for emergency services."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D32F2F"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
